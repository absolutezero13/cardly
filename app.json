{
  "expo": {
    "name": "Cardly AI",
    "slug": "cardly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/CardlyIcon.png",
    "scheme": "cardly",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/CardlyIcon.png",
      "bundleIdentifier": "com.absolutezero13.cardly",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#07111F",
        "foregroundImage": "./assets/images/CardlyIcon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.absolutezero13.cardly",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/CardlyIcon.png"
    },
    "plugins": [
      "react-native-bottom-tabs",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#07111F",
          "image": "./assets/images/CardlySplashIcon.png",
          "imageWidth": 180
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "forceStaticLinking": [
              "RNFBApp",
              "RNFBAuth",
              "RNFBStorage"
            ]
          }
        }
      ],
      "expo-image",
      [
        "expo-image-picker",
        {
          "photosPermission": "Cardly AI needs access to your photos so you can pick card images from your library.",
          "microphonePermission": false
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Cardly AI uses your camera to capture the front and back of your trading cards.",
          "enableFrameProcessors": false,
          "enableMicrophonePermission": false
        }
      ],
      "expo-video"
    ],
    "experiments": {
      "reactCompiler": true
    }
  }
}
